{
  auto_https off
}

:443 {
  tls internal
  encode gzip

  @console path /console* /auth* /org* /transform* /approvals* /benchmarks* /integrations* /status /healthz /readyz
  reverse_proxy @console amc-studio:3212

  @gateway path /openai* /anthropic* /gemini* /grok* /openrouter* /local* /__amc/health
  reverse_proxy @gateway amc-studio:3210

  handle {
    respond "AMC TLS reverse proxy" 200
  }
}
