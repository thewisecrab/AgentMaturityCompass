{
  "name": "agent-maturity-compass",
  "version": "1.0.0",
  "description": "Tamper-evident maturity diagnostic for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "amc": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js && npm run copy-assets",
    "copy-assets": "rm -rf dist/console/pages dist/console/assets dist/dashboard/templates && mkdir -p dist/console dist/dashboard && cp -r src/console/pages dist/console/pages && cp -r src/console/assets dist/console/assets && cp -r src/dashboard/templates dist/dashboard/templates",
    "dev": "tsx src/cli.ts",
    "lint": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:prepack-check": "node scripts/prepack-release-check.mjs",
    "check:incident-readiness": "node scripts/incident-readiness-check.mjs",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepack": "npm run typecheck && npm test && npm run build && npm run release:prepack-check"
  },
  "keywords": [
    "agent",
    "maturity",
    "diagnostic",
    "evidence",
    "ledger"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thewisecrab/AgentMaturityCompass.git"
  },
  "homepage": "https://thewisecrab.github.io/AgentMaturityCompass",
  "bugs": {
    "url": "https://github.com/thewisecrab/AgentMaturityCompass/issues"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "inquirer": "^12.4.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
